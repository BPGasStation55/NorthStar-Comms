# -------------------------
Releases/*.zip
Exports/Releases/*.zip

# -------------------------
# Generated Python Bytecode
# -------------------------
*.pyc

# -------------------------
# Backup Files
# -------------------------
*.bak
*.backup
*~

# -------------------------
# Secrets / Local Config
# Never commit credentials or private API keys
# -------------------------
.env.*
!.env.example
secrets/
credentials/
