# ==========================================
# NorthStar-Comms .gitignore
# ==========================================

# -------------------------
# Python
# -------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
.env

# -------------------------
# VS Code
# -------------------------
.vscode/

# -------------------------
# JetBrains IDEs
# -------------------------
.idea/

# -------------------------
# Windows
# -------------------------
Thumbs.db
Desktop.ini

# -------------------------
# macOS
# -------------------------
.DS_Store

# -------------------------
# Excel Temporary / Lock Files
# -------------------------
~$*.xlsx
~$*.xls
~$*.xlsm
*.tmp

# -------------------------
# Python Build / Packaging
# -------------------------
build/
dist/

# -------------------------
# Logs
# -------------------------
*.log

# -------------------------
# Cache / Test Artifacts
# -------------------------
.pytest_cache/
.coverage
htmlcov/

# -------------------------
# Local Scratch / Test Data
# -------------------------
scratch/
local_testing/
temp/

